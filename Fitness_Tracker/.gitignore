# .gitignore для MERN (MongoDB, Express, React, Node)
# Общие (OS / временные файлы)
.DS_Store
Thumbs.db
desktop.ini
*.swp
*~
.#*
Icon?

# Node / менеджеры пакетов
node_modules/
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*
# Если хотите отслеживать lockfile — раскомментируйте:
# package-lock.json
# yarn.lock
# pnpm-lock.yaml

# Сборки / артефакты
dist/
build/
public/build/
.cache/
.next/
.out/

# Конфиги окружения / секреты
.env
.env.*.local
.env.local
.env.production
.env.development
.env.test

# Логи, временные файлы
logs/
*.log
tmp/
temp/
pids/
*.pid

# Тесты / покрытие
coverage/
.nyc_output/
jest.config.js
jest_cache/
.vitest/

# TypeScript build info
*.tsbuildinfo

# IDE / редакторы
.idea/
.vscode/
*.sublime-workspace
*.sublime-project

# Docker
docker-compose.override.yml
.env.docker
**/docker-compose.override.yml
docker-compose.*.yml

# Базы данных (локальные данные)
# MongoDB default db path (локальные данные/дампы)
data/
data/db/
mongod.lock
dump/
*.bson
*.json

# Frontend кэш/артефакты
*.map
*.min.js
*.min.css

# OS-specific trash
.AppleDouble
.LSOverride

# Дополнительно
.coverage
.cache-loader
.cache/
eslintcache
*.log

